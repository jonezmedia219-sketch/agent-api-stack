APP_NAME=agent-api-stack
APP_VERSION=0.1.0
APP_ENV=production
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO
HTTP_TIMEOUT_SECONDS=15
HTTP_MAX_RESPONSE_BYTES=2000000
HTTP_USER_AGENT=JarvisAgentAPI/0.1
STRUCTURED_WEB_MAX_HTML_CHARS=500000
STRUCTURED_WEB_MAX_LINKS=100
CORS_ALLOW_ORIGINS=
REQUEST_MAX_BODY_BYTES=1000000
RATE_LIMIT_REQUESTS=60
RATE_LIMIT_WINDOW_SECONDS=60
ENABLE_METERING=true
ENABLE_PAYMENT_ENFORCEMENT=false
PAYMENT_SHADOW_MODE=true
PAYMENT_VERIFIER=stub
PAYMENT_CHAIN=base
PAYMENT_TOKEN=USDC
PAYMENT_RECEIVER_WALLET=0xa850773dDdAc7051c9434E3b1e804531C12d265c
# Legacy alias still accepted temporarily in code: PAYMENT_RECEIVER_WALET
PAYMENT_MAX_SKEW_SECONDS=300
PAYMENT_REQUIRE_NONCE=true
PAYMENT_SHARED_SECRET=change-me-before-production
BASE_RPC_URL=https://mainnet.base.org
PAYMENT_TOKEN_CONTRACT=0x833589fCD6EDB6E08f4c7C32D4f71b54bdA02913
PAYMENT_MIN_CONFIRMATIONS=1
